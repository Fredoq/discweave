{
  "ConnectionStrings": {
    "DiscWeave": ""
  },
  "ReleaseCovers": {
    "StorageRoot": "var/release-covers"
  },
  "Discogs": {
    "Enabled": true,
    "BaseUrl": "https://api.discogs.com",
    "UserAgent": "DiscWeave/0.1 (+https://github.com/Fredoq/discweave)",
    "TimeoutSeconds": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DiscWeave": {
    "StorageProvider": "Sqlite"
  }
}
