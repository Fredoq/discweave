{
  "ConnectionStrings": {
    "DiscWeave": "Data Source=var/discweave.sqlite"
  },
  "ReleaseCovers": {
    "StorageRoot": "var/release-covers"
  },
  "Discogs": {
    "BaseUrl": "https://api.discogs.com",
    "UserAgent": "DiscWeave/0.1 (+https://github.com/Fredoq/discweave)",
    "TimeoutSeconds": 10
  },
  "DesktopDownloads": {
    "MacOsInstallerDirectory": "../../../app/release"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
